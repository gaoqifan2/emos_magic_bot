#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""修复所有未正确结束的字符串"""

with open('main.py', 'r', encoding='utf-8') as f:
    content = f.read()

# 修复所有未正确结束的字符串
replacements = [
    ('"?游戏已经开始或已结束)', '游戏已经开始或已结束"'),
    ('"?请先使用 /start 命令登录)', '请先使用 /start 命令登录"'),
    ('"?庄家不能参与自己的游戏!")', '庄家不能参与自己的游戏!"'),
    ('"?您已经下注过了!")', '您已经下注过了!"'),
    ('"?下注命令只能在群聊中使用")', '下注命令只能在群聊中使用"'),
    ('"?当前没有正在进行的猜大小游戏, 请先使用`/createguess 大/小金额` 命令创建游戏")', '当前没有正在进行的猜大小游戏, 请先使用`/createguess 大/小 金额` 命令创建游戏"'),
    ('"?下注时间已截止, 无法再下注)', '下注时间已截止, 无法再下注"'),
    ('"?庄家已经下注, 不能重复下注!")', '庄家已经下注, 不能重复下注!"'),
    ('"?庄家模式只能在群聊中使用")', '庄家模式只能在群聊中使用"'),
    ('"?群里已经有游戏在进行中, 请等待当前游戏结束)', '群里已经有游戏在进行中, 请等待当前游戏结束"'),
    ('"?您已经参与了这个游戏)', '您已经参与了这个游戏"'),
    ('"?下注金额必须大于0, 请重新输入")', '下注金额必须大于0, 请重新输入"'),
    ('"?请输入有效的数字作为金额, 请重新输入")', '请输入有效的数字作为金额, 请重新输入"'),
    ('"?请先登录!发?/start 登录")', '请先登录!发送 /start 登录"'),
    ('"?转赠金额必须?-6000之间, 请重新输入?)', '转赠金额必须在1-6000之间, 请重新输入"'),
    ('"?请输入有效的数字, 请重新输入?)', '请输入有效的数字, 请重新输入"'),
    ('"?充值金额必须在1-50000之间, 请重新输入?)', '充值金额必须在1-50000之间, 请重新输入"'),
    ('"?只有服务商才能使用此功能")', '只有服务商才能使用此功能"'),
    ('"?转账金额必须?-50000之间, 请重新输入?)', '转账金额必须在1-50000之间, 请重新输入"'),
    ('"?订单金额必须?-50000之间, 请重新输入?)', '订单金额必须在1-50000之间, 请重新输入"'),
]

for old, new in replacements:
    content = content.replace(old, new)

with open('main.py', 'w', encoding='utf-8') as f:
    f.write(content)

print('修复完成')
